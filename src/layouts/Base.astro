---
const { title, description = "Field notes from the garage — Electronic Zoology" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Electronic Zoology</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --dark:    #1a1a2e;
      --amber:   #a855f7;
      --green:   #2ecc71;
      --text:    #222;
      --muted:   #888;
      --light:   #f5f5f5;
      --white:   #fff;
      --border:  #e0e0e0;
      --rainbow: linear-gradient(135deg, #ff6b6b, #ffd93d, #6bcb77, #4d96ff, #c77dff);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 16px;
      line-height: 1.7;
      color: var(--text);
      background: var(--light);
    }

    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--dark);
      color: var(--white);
      padding: 0 2rem;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }

    .site-name {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--white);
      text-decoration: none;
      line-height: 1.2;
    }
    .site-name span {
      background: var(--rainbow);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .site-name small {
      display: block;
      font-size: 0.65rem;
      font-weight: 400;
      color: var(--muted);
      letter-spacing: 0.5px;
      -webkit-text-fill-color: var(--muted);
    }

    header nav a {
      color: #ccc;
      text-decoration: none;
      margin-left: 1.5rem;
      font-size: 0.9rem;
      transition: color 0.15s;
    }
    header nav a:hover { color: var(--white); }
    header nav a.active {
      background: var(--rainbow);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .page-wrap {
      max-width: 860px;
      margin: 0 auto;
      padding: 3rem 1.5rem 5rem;
    }

    footer {
      text-align: center;
      padding: 2rem;
      color: var(--muted);
      font-size: 0.85rem;
    }
    footer a { color: var(--muted); text-decoration: none; }
    footer a:hover { color: var(--amber); }


    @media (max-width: 640px) {
      header { padding: 0 1rem; }
      .page-wrap { padding: 2rem 1rem 4rem; }
    }
  </style>
</head>
<body>

<header>
  <a class="site-name" href="/">Electronic<span>Zoology</span><small>field notes from the garage</small></a>
  <nav>
    <a href="/">Home</a>
    <a href="/projects">Projects</a>
    <a href="/about">About</a>
  </nav>
</header>

<div class="page-wrap">
  <slot />
</div>

<footer>
  Electronic Zoology, field notes from the Bellarine Peninsula &nbsp;&middot;&nbsp;
  <a href="#" onclick="window.scrollTo({top:0,behavior:'smooth'});return false;">Back to top &uarr;</a>
</footer>

<script is:inline data-name="BMC-Widget" data-cfasync="false" src="https://cdnjs.buymeacoffee.com/1.0.0/widget.prod.min.js" data-id="yourawesome" data-description="Support me on Buy me a coffee!" data-message="" data-color="#FF813F" data-position="Right" data-x_margin="18" data-y_margin="18"></script>

</body>
</html>
