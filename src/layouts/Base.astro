---
const { title, description = "Field notes from the garage — Electronic Zoology", fullWidth = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Electronic Zoology</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --dark:    #1a1a2e;
      --amber:   #a855f7;
      --green:   #2ecc71;
      --text:    #222;
      --muted:   #888;
      --light:   #f5f5f5;
      --white:   #fff;
      --border:  #e0e0e0;
      --rainbow: linear-gradient(135deg, #ff6b6b, #ffd93d, #6bcb77, #4d96ff, #c77dff);
    }

    html { scroll-behavior: smooth; overflow-x: hidden; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 16px;
      line-height: 1.7;
      color: var(--text);
      background: var(--light);
      overflow-x: hidden;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--dark);
      color: var(--white);
      padding: 0 2rem;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    }

    .site-name {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--white);
      text-decoration: none;
      line-height: 1.2;
    }
    .site-name span {
      background: var(--rainbow);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .site-name small {
      display: block;
      font-size: 0.65rem;
      font-weight: 400;
      color: var(--muted);
      letter-spacing: 0.5px;
      -webkit-text-fill-color: var(--muted);
    }

    header nav a {
      color: #ccc;
      text-decoration: none;
      margin-left: 1.5rem;
      font-size: 0.9rem;
      transition: color 0.15s;
    }
    header nav a:hover { color: var(--white); }
    @keyframes twinkle {
      0%, 100% { opacity: 0; transform: scale(0.3) rotate(0deg); }
      50%       { opacity: 1; transform: scale(1.2) rotate(40deg); }
    }
    .spark {
      position: absolute;
      font-size: 0.55rem;
      color: #fff;
      pointer-events: none;
      opacity: 0;
    }
    .cookie-btn.sparkling .spark {
      animation: twinkle 1.8s ease-in-out infinite;
    }
    .cookie-btn.sparkling {
      animation: shimmer 3s ease infinite;
    }
    @keyframes shimmer {
      0%   { background-position: 0% 50%; }
      50%  { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    header nav a.cookie-btn {
      position: relative;
      display: inline-block;
      background: linear-gradient(135deg, #c97b7b, #c9a84c, #5a9e6f, #4a7fc1, #9b6fc9, #c97b7b);
      background-size: 300% 300%;
      color: #fff !important;
      font-weight: 700;
      font-size: 0.52rem;
      padding: 0.08rem 0.3rem;
      border-radius: 6px;
      transform: rotate(-7deg);
      transition: transform 0.15s, opacity 0.15s;
      text-shadow: 0 1px 2px rgba(0,0,0,0.3);
    }
    header nav a.cookie-btn:hover { opacity: 0.9; transform: rotate(0deg); }
    header nav a.active {
      background: var(--rainbow);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .page-wrap {
      max-width: 860px;
      margin: 0 auto;
      padding: 3rem 1.5rem 5rem;
    }

    footer {
      text-align: center;
      padding: 2rem;
      color: var(--muted);
      font-size: 0.85rem;
    }
    footer a { color: var(--muted); text-decoration: none; }
    footer a:hover { color: var(--amber); }
    .bmc-btn {
      display: inline-block;
      background: #FF813F;
      color: #fff !important;
      font-weight: 700;
      font-size: 0.85rem;
      padding: 0.45rem 1rem;
      border-radius: 6px;
      text-decoration: none;
      margin-bottom: 1.2rem;
      transform: rotate(-7deg);
      transition: transform 0.15s, opacity 0.15s;
    }
    .bmc-btn:hover { opacity: 0.9; transform: rotate(0deg); }


    @media (max-width: 640px) {
      header {
        height: auto;
        padding: 0.75rem 1rem;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
      }
      header nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem 0;
      }
      header nav a {
        margin-left: 0;
        margin-right: 1rem;
        font-size: 0.85rem;
      }
      header nav a.cookie-btn {
        font-size: 0.72rem;
        padding: 0.3rem 0.7rem;
        transform: rotate(-4deg);
      }
      .page-wrap { padding: 2rem 1rem 4rem; }
    }
  </style>
</head>
<body>

<header>
  <a class="site-name" href="/">Electronic<span>Zoology</span><small>field notes from the garage</small></a>
  <nav>
    <a href="/">Home</a>
    <a href="/guides">Guides</a>
    <a href="/projects">Projects</a>
    <a href="/about">About</a>
    <a href="https://buymeacoffee.com/yourawesome" target="_blank" rel="noopener" class="cookie-btn">
  <span class="spark" style="top:-7px;left:2px;animation-delay:0s">✦</span>
  <span class="spark" style="top:-8px;left:12%;animation-delay:0.1s">✧</span>
  <span class="spark" style="top:-6px;left:25%;animation-delay:0.2s">✦</span>
  <span class="spark" style="top:-8px;left:38%;animation-delay:0.3s">✧</span>
  <span class="spark" style="top:-6px;left:52%;animation-delay:0.4s">✦</span>
  <span class="spark" style="top:-8px;left:66%;animation-delay:0.5s">✧</span>
  <span class="spark" style="top:-7px;left:80%;animation-delay:0.6s">✦</span>
  <span class="spark" style="top:-6px;right:2px;animation-delay:0.7s">✧</span>
  <span class="spark" style="bottom:-7px;left:2px;animation-delay:0.08s">✧</span>
  <span class="spark" style="bottom:-8px;left:15%;animation-delay:0.18s">✦</span>
  <span class="spark" style="bottom:-6px;left:30%;animation-delay:0.28s">✧</span>
  <span class="spark" style="bottom:-8px;left:45%;animation-delay:0.38s">✦</span>
  <span class="spark" style="bottom:-6px;left:60%;animation-delay:0.48s">✧</span>
  <span class="spark" style="bottom:-8px;left:75%;animation-delay:0.58s">✦</span>
  <span class="spark" style="bottom:-6px;right:2px;animation-delay:0.68s">✧</span>
  <span class="spark" style="top:0px;left:-7px;animation-delay:0.15s">✦</span>
  <span class="spark" style="top:40%;left:-8px;animation-delay:0.45s">✧</span>
  <span class="spark" style="top:0px;right:-7px;animation-delay:0.25s">✦</span>
  <span class="spark" style="top:40%;right:-8px;animation-delay:0.55s">✧</span>
  🍪 <em>buy me a cookie</em>
</a>
  </nav>
</header>

{fullWidth ? <slot /> : <div class="page-wrap"><slot /></div>}

<footer>
  Electronic Zoology, field notes from the Bellarine Peninsula (Bellawiyn Country) &nbsp;&middot;&nbsp;
  <a href="#" onclick="window.scrollTo({top:0,behavior:'smooth'});return false;">Back to top &uarr;</a>
</footer>

<script>
  const btn = document.querySelector('.cookie-btn');
  let t;
  window.addEventListener('scroll', () => {
    btn.classList.add('sparkling');
    clearTimeout(t);
    t = setTimeout(() => btn.classList.remove('sparkling'), 1000);
  }, { passive: true });
</script>
</body>
</html>
