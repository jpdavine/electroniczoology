  }
  .hero .meta-item strong { color: #fff; }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #2ecc71;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 700;
