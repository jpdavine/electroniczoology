---
import Base from '../../layouts/Base.astro';

const guides = [
  {
    slug: 'pam8403-esp32-audio',
    title: 'PAM8403 Audio Amplifier with ESP32',
    description: 'Playing audio clips from an ESP32 dev board through a PAM8403 amplifier and a speaker. Covers wiring, audio prep, WAV-to-header conversion, and the full Arduino sketch.',
    category: 'Audio',
    date: '2026-04-16',
    status: 'confirmed',
    tags: ['ESP32', 'PAM8403', 'Audio', 'Arduino'],
  },
  {
    slug: 'gc9a01-round-display-esp32',
    title: 'GC9A01 Round TFT Display with ESP32',
    description: 'Wiring and driving a GC9A01 240x240 round IPS TFT display with an ESP32 Dev Board over SPI. Covers library setup, wiring, and a confirmed working test sketch.',
    category: 'Display',
    date: '2026-04-22',
    status: 'confirmed',
    tags: ['ESP32', 'GC9A01', 'TFT', 'SPI', 'Arduino'],
  },
  {
    slug: 'gc9a01-custom-image',
    title: 'Display a Custom Image on the GC9A01 Round TFT',
    description: 'Convert any image to RGB565 and display it on a GC9A01 240x240 round IPS TFT with an ESP32. Covers image prep in GIMP, the Python conversion script, and the full Arduino sketch.',
    category: 'Display',
    date: '2026-04-28',
    status: 'confirmed',
    tags: ['ESP32', 'GC9A01', 'RGB565', 'Images', 'Python', 'Arduino'],
  },
  {
    slug: 'gc9a01-multiple-images',
    title: 'Cycling Multiple Images on the GC9A01 Round TFT',
    description: 'Batch convert a folder of images to RGB565 and cycle through them on a GC9A01 round display. Covers batch conversion, flash memory limits, partition scheme, and the full cycling sketch.',
    category: 'Display',
    date: '2026-04-28',
    status: 'wip',
    tags: ['ESP32', 'GC9A01', 'RGB565', 'Images', 'Python', 'Arduino'],
  },
];
---
<Base title="Guides">

  <div class="page-header">
    <div class="section-label">Field Notes</div>
    <h1>The Guides</h1>
    <p>Step-by-step guides built on real hardware in the garage. Confirmed working means tested and verified. Untested means the code is written but not yet run on hardware.</p>
  </div>

  <div class="guide-list">
    {guides.map((g) => (
      <a class="guide-row" href={`/guides/${g.slug}`}>
        <div class="row-meta">
          <span class="row-category">{g.category}</span>
          <span class={`row-badge ${g.status === 'untested' ? 'row-badge-untested' : g.status === 'wip' ? 'row-badge-wip' : ''}`}>
            {g.status === 'untested' ? '⚠ Untested' : g.status === 'wip' ? '⚙ Under Construction' : '✓ Confirmed Working'}
          </span>
          <span class="row-date">{new Date(g.date).toLocaleDateString('en-AU', { year: 'numeric', month: 'short' })}</span>
        </div>
        <h2>{g.title}</h2>
        <p>{g.description}</p>
        {g.tags && (
          <div class="tags">
            {g.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
        )}
      </a>
    ))}
  </div>

</Base>

<style>
  .page-header { margin-bottom: 2.5rem; }
  .section-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    background: linear-gradient(135deg, #ff6b6b, #ffd93d, #6bcb77, #4d96ff, #c77dff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }
  .page-header h1 {
    font-size: 2rem;
    font-weight: 800;
    color: #1a1a2e;
    margin-bottom: 0.5rem;
  }
  .page-header p { color: #555; }

  .guide-list { display: flex; flex-direction: column; gap: 1rem; }

  .guide-row {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 1.5rem 2rem;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .guide-row:hover {
    border-color: #a855f7;
    box-shadow: 0 4px 16px rgba(168,85,247,0.08);
  }

  .row-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.4rem;
    flex-wrap: wrap;
  }
  .row-category {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #a855f7;
  }
  .row-badge {
    font-size: 0.7rem;
    font-weight: 700;
    color: #fff;
    background: #2ecc71;
    padding: 0.1rem 0.55rem;
    border-radius: 20px;
    letter-spacing: 0.5px;
  }
  .row-badge-untested { background: #e67e22; }
  .row-badge-wip { background: #6b7280; }
  .row-date { font-size: 0.8rem; color: #888; }

  .guide-row h2 {
    font-size: 1.15rem;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 0.4rem;
  }
  .guide-row p { font-size: 0.9rem; color: #555; line-height: 1.6; }

  .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.75rem; }
  .tag {
    font-size: 0.75rem;
    background: #f0f0f0;
    color: #555;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
  }
</style>
