---
import Base from '../../layouts/Base.astro';

const guides = [
  {
    slug: 'max98357a-wiring-tone-test',
    title: 'MAX98357A I2S - Wiring & Tone Test',
    description: 'Wire up a MAX98357A I2S amplifier to an ESP32 Dev Board or ESP32-C3 and confirm it works with a 440Hz tone test sketch. No audio files needed.',
    category: 'Audio',
    date: '2026-04-29',
    status: 'confirmed',
    series: 'MAX98357A I2S Series',
    step: 1,
    stepDesc: 'Wiring & tone test',
    tags: ['ESP32', 'ESP32-C3', 'MAX98357A', 'I2S', 'Audio', 'Arduino'],
  },
  {
    slug: 'max98357a-esp32-audio',
    title: 'MAX98357A I2S Amplifier - ESP32 Dev Board & ESP32-C3',
    description: 'Play audio on an ESP32 Dev Board or ESP32-C3 using a MAX98357A I2S amplifier. Digital audio direct from the ESP32 - no DAC, no caps. Covers audio prep, WAV-to-header conversion, and the full sketch.',
    category: 'Audio',
    date: '2026-04-29',
    status: 'confirmed',
    series: 'MAX98357A I2S Series',
    step: 2,
    stepDesc: 'Playing a clip from PROGMEM',
    tags: ['ESP32', 'ESP32-C3', 'MAX98357A', 'I2S', 'Audio', 'Arduino'],
  },
  {
    slug: 'max98357a-multiple-clips',
    title: 'Multiple Audio Clips - MAX98357A I2S',
    description: 'Play multiple audio clips on an ESP32 with a MAX98357A I2S amplifier. Button trigger, auto sequence, and linked playlist modes.',
    category: 'Audio',
    date: '2026-04-29',
    status: 'wip',
    series: 'MAX98357A I2S Series',
    step: 3,
    stepDesc: 'Multiple clips - button, sequence, playlist',
    tags: ['ESP32', 'ESP32-C3', 'MAX98357A', 'I2S', 'Audio', 'Arduino'],
  },
  {
    slug: 'pam8403-esp32-audio',
    title: 'PAM8403 Audio Amplifier with ESP32',
    description: 'Playing audio clips from an ESP32 dev board through a PAM8403 amplifier and a speaker. Covers wiring, audio prep, WAV-to-header conversion, and the full Arduino sketch.',
    category: 'Audio',
    date: '2026-04-16',
    status: 'confirmed',
    tags: ['ESP32', 'PAM8403', 'Audio', 'Arduino'],
  },
  {
    slug: 'tft-espi-esp32',
    title: 'TFT_eSPI with ESP32 - All Displays, One Library',
    description: 'How to use TFT_eSPI by Bodmer to drive SPI displays on an ESP32. One library, one API, swap displays by changing a config file. Covers setup, User_Setup.h, wiring, and a test sketch for ST7735, ST7789, and GC9A01.',
    category: 'Display',
    date: '2026-04-29',
    status: 'confirmed',
    series: 'TFT_eSPI Library Tutorial',
    tags: ['ESP32', 'TFT_eSPI', 'SPI', 'Arduino'],
  },
  {
    slug: 'gc9d01-round-display-esp32',
    title: 'GC9D01 160x160 Round TFT with ESP32',
    description: 'Wire and drive a GC9D01 160x160 round TFT with an ESP32. Covers the common GC9A01 mislabelling problem, correct library and constructor, wiring gotchas, and a confirmed working test sketch.',
    category: 'Display',
    date: '2026-04-29',
    status: 'confirmed',
    tags: ['ESP32', 'GC9D01', 'Arduino_GFX', 'SPI', 'Arduino'],
  },
  {
    slug: 'gc9a01-round-display-esp32',
    title: 'GC9A01 Round TFT Display with ESP32',
    description: 'Wiring and driving a GC9A01 240x240 round IPS TFT display with an ESP32 Dev Board over SPI. Covers library setup, wiring, and a confirmed working test sketch.',
    category: 'Display',
    date: '2026-04-22',
    status: 'confirmed',
    series: 'GC9A01 Display Series',
    step: 1,
    stepDesc: 'Wiring and first display',
    tags: ['ESP32', 'GC9A01', 'TFT', 'SPI', 'Arduino'],
  },
  {
    slug: 'gc9a01-custom-image',
    title: 'Display a Custom Image on the GC9A01',
    description: 'Convert any image to RGB565 and display it on a GC9A01 240x240 round IPS TFT with an ESP32. Covers image prep in GIMP, the Python conversion script, and the full Arduino sketch.',
    category: 'Display',
    date: '2026-04-28',
    status: 'confirmed',
    series: 'GC9A01 Display Series',
    step: 2,
    stepDesc: 'Custom image from PROGMEM',
    tags: ['ESP32', 'GC9A01', 'RGB565', 'Images', 'Python', 'Arduino'],
  },
  {
    slug: 'gc9a01-multiple-images',
    title: 'Cycling Multiple Images on the GC9A01',
    description: 'Batch convert a folder of images to RGB565 and cycle through them on a GC9A01 round display. Covers batch conversion, flash memory limits, partition scheme, and the full cycling sketch.',
    category: 'Display',
    date: '2026-04-28',
    status: 'confirmed',
    series: 'GC9A01 Display Series',
    step: 3,
    stepDesc: 'Cycling images - batch conversion and memory',
    tags: ['ESP32', 'GC9A01', 'RGB565', 'Images', 'Python', 'Arduino'],
  },
];

// Build tree preserving guide order
const categoryOrder: string[] = [];
const tree: Record<string, Array<
  | { type: 'series'; name: string; guides: typeof guides }
  | { type: 'standalone'; guide: (typeof guides)[0] }
>> = {};

for (const g of guides) {
  if (!tree[g.category]) {
    tree[g.category] = [];
    categoryOrder.push(g.category);
  }
  if (g.series) {
    const existing = tree[g.category].find(n => n.type === 'series' && n.name === g.series) as { type: 'series'; name: string; guides: typeof guides } | undefined;
    if (existing) {
      existing.guides.push(g);
    } else {
      tree[g.category].push({ type: 'series', name: g.series, guides: [g] });
    }
  } else {
    tree[g.category].push({ type: 'standalone', guide: g });
  }
}

const totalCount = guides.length;
const catCounts = Object.fromEntries(categoryOrder.map(cat => [cat, guides.filter(g => g.category === cat).length]));
---
<Base title="Guides">

  <div class="page-header">
    <div class="section-label">Field Notes</div>
    <h1>The Guides</h1>
    <p>Step-by-step guides built on real hardware in the garage. Confirmed working means tested and verified. Untested means the code is written but not yet run on hardware.</p>
  </div>

  <div class="cat-filter">
    <button class="cat-btn active" data-filter="all">All ({totalCount})</button>
    {categoryOrder.map(cat => (
      <button class="cat-btn" data-filter={cat}>{cat} ({catCounts[cat]})</button>
    ))}
  </div>

  <div class="guide-tree">
    {categoryOrder.map(cat => (
      <div class="tree-category" data-cat={cat}>
        <div class="tree-cat-header">
          <span class="tree-cat-label">{cat}</span>
        </div>

        <div class="tree-branch">
          {tree[cat].map(node => {
            if (node.type === 'series') {
              return (
                <div class="tree-node">
                  <div class="tree-series-label">{node.name}</div>
                  <div class="tree-subbranch">
                    {node.guides.map(g => (
                      <a class="tree-leaf" href={`/guides/${g.slug}`}>
                        <span class="leaf-left">
                          {g.step && <span class="leaf-step">Step {g.step}</span>}
                          <span class="leaf-title">{g.stepDesc || g.title}</span>
                        </span>
                        <span class={`leaf-badge ${g.status === 'untested' ? 'badge-untested' : g.status === 'wip' ? 'badge-wip' : 'badge-confirmed'}`}>
                          {g.status === 'untested' ? '⚠ Untested' : g.status === 'wip' ? '⚙ WIP' : '✓ Confirmed'}
                        </span>
                      </a>
                    ))}
                  </div>
                </div>
              );
            } else {
              return (
                <a class="tree-leaf tree-leaf-root" href={`/guides/${node.guide.slug}`}>
                  <span class="leaf-left">
                    <span class="leaf-title">{node.guide.title}</span>
                  </span>
                  <span class={`leaf-badge ${node.guide.status === 'untested' ? 'badge-untested' : node.guide.status === 'wip' ? 'badge-wip' : 'badge-confirmed'}`}>
                    {node.guide.status === 'untested' ? '⚠ Untested' : node.guide.status === 'wip' ? '⚙ WIP' : '✓ Confirmed'}
                  </span>
                </a>
              );
            }
          })}
        </div>
      </div>
    ))}
  </div>

</Base>

<style>
  .page-header { margin-bottom: 2.5rem; }
  .section-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    background: linear-gradient(135deg, #ff6b6b, #ffd93d, #6bcb77, #4d96ff, #c77dff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 0.5rem;
  }
  .page-header h1 {
    font-size: 2rem;
    font-weight: 800;
    color: #1a1a2e;
    margin-bottom: 0.5rem;
  }
  .page-header p { color: #555; }

  /* Filter buttons */
  .cat-filter {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .cat-btn {
    background: #f0f0f0;
    color: #555;
    border: none;
    border-radius: 20px;
    padding: 0.4rem 1.1rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .cat-btn:hover { background: #e8e0ff; color: #a855f7; }
  .cat-btn.active { background: #a855f7; color: #fff; }

  /* Tree */
  .guide-tree {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Category block */
  .tree-category {}

  .tree-cat-header {
    margin-bottom: 0.6rem;
  }
  .tree-cat-label {
    font-size: 0.68rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: #bbb;
  }

  /* Main branch - vertical line down the left */
  .tree-branch {
    border-left: 2px solid #e8e8e8;
    margin-left: 0.4rem;
    display: flex;
    flex-direction: column;
  }

  /* Series node */
  .tree-node {
    display: flex;
    flex-direction: column;
    margin-bottom: 0.5rem;
  }

  .tree-series-label {
    position: relative;
    padding: 0.55rem 0.75rem 0.55rem 1.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
    color: #a855f7;
  }
  .tree-series-label::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 1.25rem;
    height: 2px;
    background: #e8e8e8;
  }

  /* Sub-branch for series guides */
  .tree-subbranch {
    border-left: 2px solid #ece8f8;
    margin-left: 1.75rem;
    display: flex;
    flex-direction: column;
    margin-bottom: 0.5rem;
  }

  /* Guide leaf */
  .tree-leaf {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.6rem 1rem 0.6rem 1.5rem;
    text-decoration: none;
    color: inherit;
    border-radius: 0 6px 6px 0;
    transition: background 0.12s;
  }
  .tree-leaf::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 1.25rem;
    height: 2px;
    background: #ece8f8;
  }
  .tree-leaf:hover { background: #faf6ff; }

  /* Root-level standalone guide (direct child of .tree-branch) */
  .tree-leaf-root {
    margin: 0.2rem 0;
  }
  .tree-leaf-root::before {
    background: #e8e8e8;
  }

  .leaf-left {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex: 1;
    min-width: 0;
  }

  .leaf-step {
    font-size: 0.68rem;
    font-weight: 700;
    background: #f3e8ff;
    color: #a855f7;
    padding: 0.15rem 0.5rem;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .leaf-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: #1a1a2e;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .leaf-badge {
    font-size: 0.68rem;
    font-weight: 700;
    color: #fff;
    padding: 0.15rem 0.6rem;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .badge-confirmed { background: #2ecc71; }
  .badge-untested { background: #e67e22; }
  .badge-wip { background: #6b7280; }
</style>

<script is:inline>
  document.querySelectorAll('.cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.tree-category').forEach(el => {
        el.style.display = filter === 'all' || el.dataset.cat === filter ? '' : 'none';
      });
    });
  });
</script>
